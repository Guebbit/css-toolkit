{
    "name": "@guebbit/css-toolkit",
    "type": "module",
    "version": "2.0",
    "description": "A repository containing helpful CSS functions, mixins, and utilities for streamlining and standardizing CSS development",
    "main": "index.js",
    "files": [
        "docs",
        "src",
        "test",
        "index.css",
        "index.js",
        "postcss.config.js",
        "README.md",
        "LICENSE",
        "CHANGELOG",
        "vite.config.ts"
    ],
    "scripts": {
        "test": "mocha",
        "lint": "stylelint \"index.css\" \"src/**/*.css\" --fix",
        "prettier": "npx prettier . --write",
        "docs:dev": "vitepress dev docs --port 8080",
        "docs:build": "vitepress build docs",
        "docs:serve": "vitepress serve docs --port 8080",
        "update:all": "npx npm-check-updates -u",
        "complete": "npm run lint && npm run prettier && npm run test && npm run docs:build",
        "publish:public": "npm publish --access public"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "autoprefixer": "^10.4.27",
        "chai": "^6.2.2",
        "css-loader": "^7.1.4",
        "cssnano": "^7.1.4",
        "mocha": "^11.7.5",
        "postcss": "^8.5.8",
        "postcss-import": "^16.1.1",
        "postcss-loader": "^8.2.1",
        "postcss-mixins": "^12.1.2",
        "postcss-nesting": "^14.0.0",
        "postcss-prefix-selector": "^2.1.1",
        "prettier": "^3.8.1",
        "style-loader": "^4.0.0",
        "stylelint": "^17.6.0",
        "stylelint-config-standard": "^40.0.0",
        "vite": "^8.0.3",
        "vitepress": "^1.6.4"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Guebbit/css-toolkit.git"
    },
    "keywords": [
        "CSS",
        "Library",
        "PostCSS"
    ],
    "author": "Guebbit <guerzoni.andrea91@gmail.com> (https://guebbit.com/)",
    "license": "AGPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/Guebbit/css-toolkit/issues"
    },
    "homepage": "https://github.com/Guebbit/css-toolkit#readme"
}
